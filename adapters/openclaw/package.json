{
  "name": "@persona-engine/openclaw-adapter",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.4.5",
      "minGatewayVersion": ">=2026.4.5"
    },
    "build": {
      "openclawVersion": "2026.4.5",
      "pluginSdkVersion": "2026.4.5"
    }
  },
  "files": [
    "dist/",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "test": "vitest run test/*.test.ts",
    "test:integration": "npm run build && node test/integration/run.mjs"
  },
  "dependencies": {
    "@persona-engine/core": "*",
    "@sinclair/typebox": "0.34.49"
  }
}
